# Server Configuration
PORT=3002
NODE_ENV=production
API_KEY=maimbro@#097

# Path Configuration
DATA_PATH=/data
COOKIE_PATH=/data/cookies
TEMP_PATH=/data/temp
CACHE_PATH=/data/cache
LOG_PATH=/data/logs
DB_PATH=/data/database.sqlite
BACKUP_PATH=/data/backups

# Cookie Management
COOKIE_FAIL_THRESHOLD=5
MAX_COOKIE_AGE_DAYS=30
COOKIE_REFRESH_INTERVAL_HOURS=24
COOKIE_ROTATION_STRATEGY=weighted

# Cache Configuration
CACHE_TTL_HOURS=24
MAX_CACHE_SIZE_MB=500
MAX_CACHE_FILES=1000
PREVIEW_CACHE_TTL_HOURS=1
THUMBNAIL_CACHE_TTL_HOURS=168

# Download Configuration
MAX_CONCURRENT_DOWNLOADS=5
MAX_FILE_SIZE=10737418240
TEMP_RETENTION_HOURS=1
DOWNLOAD_TIMEOUT=3600
CHUNK_SIZE=10485760

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_MAX_DOWNLOADS=20

# Proxy Configuration
PROXY_ENABLED=false
PROXY_TIMEOUT=30000
PROXY_MAX_REDIRECTS=5
ROTATING_PROXIES=false
PROXY_LIST_PATH=/data/proxies.txt

# Performance
MAX_MEMORY_CACHE_MB=100
WORKER_THREADS=4
FFMPEG_THREADS=2

# Security
CORS_ORIGIN=*
ENABLE_RATE_LIMITING=true
ENABLE_REQUEST_LOGGING=true
API_KEY_HEADER=X-API-Key

# Logging
LOG_LEVEL=info
LOG_RETENTION_DAYS=30
ENABLE_CONSOLE_LOG=true

# Backup
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=7
